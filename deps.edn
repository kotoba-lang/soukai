{:paths ["src"]
 ;; langgraph brings langchain transitively (both zero-/single-dep, all .cljc
 ;; → portable to JVM / SCI / ClojureScript / GraalVM). Same runtime koyomi/
 ;; kekkai/tayori ride on; a shareholders'-meeting-governance control plane is
 ;; just another sealed-intelligence ⊣ independent-governor StateGraph.
 ;;
 ;; Still no kotoba-lang/calendar (soukai has no separate calendar-invite
 ;; artifact — see soukai.distribute's namespace docstring), but soukai.
 ;; distribute's REAL Resend NoticeTarget now builds its request via
 ;; kotoba-lang/mailer (which itself depends on kotoba-lang/mail for
 ;; mail.message/mail.draft/mail.receipt) rather than reimplementing Resend
 ;; request-building — same layering koyomi.distribute rides on.
 ;; soukai.noticeport's mock-noticeport (the default) stays untouched by this.
 :deps {io.github.kotoba-lang/langgraph
        {:git/url "https://github.com/kotoba-lang/langgraph.git"
         :sha "5b4e5e70837b849b14b6a5800894e3be202ad5fa"}
        ;; canonical did:key + IPNS-name derivation (ADR-2607050100) — same
        ;; copy koyomi/kekkai/tayori's CACAO issuance uses.
        io.github.kotoba-lang/ed25519
        {:sha "fdcefb9f1b83461fee54d04b63e374fa301ee847"}
        io.github.kotoba-lang/ipns
        {:sha "f2563eb1cb010c96f6dec1dfbd468fac93367498"}
        ;; soukai.distribute owns the network call + JSON envelope itself
        ;; (mirrors koyomi.distribute's charter: "only this namespace touches
        ;; the network ... mail.*/mailer.* stay pure") — same lightweight
        ;; org.clojure/data.json choice koyomi's deps.edn lists.
        io.github.kotoba-lang/mailer
        {:local/root "../mailer"}
        io.github.kotoba-lang/mail
        {:local/root "../mail"}
        org.clojure/data.json
        {:mvn/version "2.5.1"}}
 :aliases
 {;; offline workspace dev alias — kept empty (no local/root override): unlike
  ;; koyomi (which overrides io.github.kotoba-lang/langchain to a ../langchain
  ;; sibling), soukai has no langchain sibling checkout to pin against here;
  ;; langgraph's own :git/sha pin on io.github.kotoba-lang/langchain resolves
  ;; transitively. mailer/mail above are already regular :local/root :deps
  ;; entries (not a :dev override — see soukai.distribute), same shape koyomi
  ;; uses for its own mailer/mail deps.
  :dev {}
  ;; clojure -M:dev:run  → drive a meeting lifecycle through one MeetingActor
  :run {:main-opts ["-m" "soukai.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main" "--lint" "src" "test" "--fail-level" "error"]}}}
