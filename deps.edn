{:paths ["src"]
 ;; langgraph brings langchain transitively (both zero-/single-dep, all .cljc
 ;; → portable to JVM / SCI / ClojureScript / GraalVM). Same runtime koyomi/
 ;; kekkai/tayori ride on; a shareholders'-meeting-governance control plane is
 ;; just another sealed-intelligence ⊣ independent-governor StateGraph.
 ;;
 ;; Deliberately dependency-lean vs. koyomi (ADR-2607121700 §6 / README): NO
 ;; kotoba-lang/calendar, NO kotoba-lang/mailer, NO kotoba-lang/mail, and NO
 ;; :local/root override — soukai's NoticeTarget port ships mock-only for
 ;; this version (soukai.noticeport), so it needs no sibling checkouts and
 ;; builds cleanly from an isolated scratch directory.
 :deps {io.github.kotoba-lang/langgraph
        {:git/url "https://github.com/kotoba-lang/langgraph.git"
         :sha "5b4e5e70837b849b14b6a5800894e3be202ad5fa"}
        ;; canonical did:key + IPNS-name derivation (ADR-2607050100) — same
        ;; copy koyomi/kekkai/tayori's CACAO issuance uses.
        io.github.kotoba-lang/ed25519
        {:sha "fdcefb9f1b83461fee54d04b63e374fa301ee847"}
        io.github.kotoba-lang/ipns
        {:sha "f2563eb1cb010c96f6dec1dfbd468fac93367498"}}
 :aliases
 {;; offline workspace dev alias — kept empty (no local/root override) since
  ;; this repo has no sibling checkouts to pin against; langgraph's own
  ;; :git/sha pin on io.github.kotoba-lang/langchain resolves transitively.
  :dev {}
  ;; clojure -M:dev:run  → drive a meeting lifecycle through one MeetingActor
  :run {:main-opts ["-m" "soukai.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main" "--lint" "src" "test" "--fail-level" "error"]}}}
